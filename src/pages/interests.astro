---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Interests | Vaidehi Pujary">
  <section class="page-header">
    <p class="eyebrow">Interests</p>
    <h1>Patterns, light, nature, and space</h1>
    <p>
      A small space for photography, hiking, mathematical art, optics-inspired
      visuals, and observations outside formal technical work.
    </p>
  </section>

  <section class="section">
    <div class="card-grid">
      <article class="project-card">
        <h3>Photography</h3>
        <p>Light, perspective, landscapes, and visual details.</p>
      </article>

      <article class="project-card">
        <h3>Hiking & Nature</h3>
        <p>Natural patterns, trails, textures, and field observations.</p>
      </article>

      <article class="project-card">
        <h3>Mathematical Art</h3>
        <p>Simple rules giving rise to structure, rhythm, and beauty.</p>
      </article>
    </div>
  </section>
</BaseLayout>